# Local backend environment template.
# Copy to backend/.env (or backend/.env.local), then fill real values.

APP_VERSION=reminder-autopush-local
PORT=18080

# Required for token sealing (used by front-end to protect GitHub token at rest).
PAT_WRAP_KEY_VERSION=v1
PAT_WRAP_KEY_BASE64=<32-byte-base64>

# Required for Web Push.
VAPID_PUBLIC_KEY=<your-vapid-public-key>
VAPID_PRIVATE_KEY=<your-vapid-private-key>
VAPID_SUBJECT=mailto:you@example.com

# Required for /internal/tick endpoint protection.
INTERNAL_TICK_TOKEN=<random-hex-token>

# Required for reminder push tick scan to read/write GitHub records.
TICK_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
TICK_GITHUB_OWNER=<github-owner>
TICK_GITHUB_REPO=<github-repo>
TICK_GITHUB_BRANCH=<optional-branch-or-empty>
TICK_GITHUB_RECORDS_DIR=data/records

# Optional: set explicit CORS allow-list (comma-separated).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://<your-user>.github.io
